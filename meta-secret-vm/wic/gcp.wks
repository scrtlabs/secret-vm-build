part /boot --source bootimg-efi --ondisk sda --fstype=vfat --label boot --active --align 1024 --sourceparams="loader=grub-efi,initrd=secret-vm-initramfs-${MACHINE}.rootfs.${INITRAMFS_FSTYPES}" --use-uuid
part / --source rootfs --ondisk sdb --fstype=ext4 --label root --active --align 1024 --use-uuid
bootloader --ptable gpt --timeout=0 --append="console=ttyS0 loglevel=7 initrd=initrd"
